#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local real-device debug captures and migration scratch files
/*.xml
/*.png
/*_verify.txt
/project_compare.txt
/swb_path.txt
/tools_check.txt
/vmrun_test.txt
/recopy_verify.txt

# Large/raw device evidence should be archived outside git unless explicitly
# curated into a small manifest-backed evidence set.
/docs/evidence/*.zip
/docs/evidence/device-current-screen*.png
